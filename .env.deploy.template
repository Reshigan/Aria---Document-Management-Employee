# ARIA ERP & AI Bot Platform - Deployment Configuration
# Copy this file to .env and update with your actual values

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
POSTGRES_USER=aria
POSTGRES_PASSWORD=CHANGE_THIS_SECURE_PASSWORD
POSTGRES_DB=aria_db
POSTGRES_PORT=5432

# =============================================================================
# REDIS CONFIGURATION
# =============================================================================
REDIS_PORT=6379

# =============================================================================
# SECURITY & AUTHENTICATION
# =============================================================================
# Generate a secure secret key (minimum 32 characters)
# Example: openssl rand -hex 32
SECRET_KEY=CHANGE_THIS_TO_A_LONG_SECURE_RANDOM_STRING_MIN_32_CHARS

# JWT Token expiration in minutes
ACCESS_TOKEN_EXPIRE_MINUTES=30

# =============================================================================
# AI SERVICE API KEYS
# =============================================================================
# Optional: For advanced AI features
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# =============================================================================
# APPLICATION CONFIGURATION
# =============================================================================
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=info

# =============================================================================
# PORTS
# =============================================================================
BACKEND_PORT=8000
FRONTEND_PORT=12000

# =============================================================================
# CORS CONFIGURATION
# =============================================================================
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:12000,http://localhost:12001,https://work-1-rkasyntaaioiwqjt.prod-runtime.all-hands.dev,https://work-2-rkasyntaaioiwqjt.prod-runtime.all-hands.dev

# =============================================================================
# FRONTEND CONFIGURATION
# =============================================================================
VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000
NODE_ENV=production

# =============================================================================
# FEATURE FLAGS
# =============================================================================
ENABLE_BOTS=true
ENABLE_OCR=true
ENABLE_ANALYTICS=true

# =============================================================================
# INTEGRATION SETTINGS (Optional)
# =============================================================================
# SAP Integration
SAP_HOST=
SAP_SYSTEM_NUMBER=
SAP_CLIENT=
SAP_USER=
SAP_PASSWORD=

# WhatsApp/Twilio Integration
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=

# Office 365 Integration
OFFICE365_CLIENT_ID=
OFFICE365_CLIENT_SECRET=
OFFICE365_TENANT_ID=

# =============================================================================
# MONITORING & OBSERVABILITY (Optional)
# =============================================================================
SENTRY_DSN=
PROMETHEUS_ENABLED=false
