{
  "name": "aria-erp-frontend",
  "version": "1.0.0",
  "type": "module",
    "scripts": {
      "dev": "vite --host 0.0.0.0 --port 12001",
      "build": "vite build",
      "preview": "vite preview --host 0.0.0.0 --port 12001",
      "test": "npm run test:unit && npm run test:e2e",
      "test:unit": "vitest run",
      "test:unit:watch": "vitest",
      "test:unit:coverage": "vitest run --coverage",
      "test:e2e": "npx playwright test",
      "test:e2e:ui": "npx playwright test --ui",
      "test:e2e:headed": "npx playwright test --headed",
      "test:e2e:debug": "npx playwright test --debug",
      "test:full": "FRONTEND_URL=https://aria.vantax.co.za npx playwright test full-system-test.spec.ts",
      "test:api": "FRONTEND_URL=https://aria.vantax.co.za npx playwright test api-integration.spec.ts",
      "test:smoke": "FRONTEND_URL=https://aria.vantax.co.za npx playwright test smoke.spec.ts",
      "test:auth": "FRONTEND_URL=https://aria.vantax.co.za npx playwright test auth.spec.ts",
      "test:erp": "FRONTEND_URL=https://aria.vantax.co.za npx playwright test erp-modules.spec.ts",
      "test:report": "npx playwright show-report",
      "test:install": "npx playwright install",
      "test:coverage": "vitest run --coverage --reporter=json --outputFile=coverage/coverage.json",
      "test:all": "npm run test:unit:coverage && npm run test:e2e"
    },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^7.3.5",
    "@mui/material": "^7.3.5",
    "axios": "^1.6.2",
    "i18next": "^25.8.0",
    "i18next-browser-languagedetector": "^8.2.0",
    "lucide-react": "^0.294.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-i18next": "^16.5.3",
    "react-router-dom": "^6.20.0",
    "recharts": "^2.10.3",
    "zustand": "^4.4.7"
  },
  "devDependencies": {
    "@playwright/test": "^1.56.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@vitejs/plugin-react": "^4.2.1",
    "@vitest/coverage-v8": "^4.0.18",
    "autoprefixer": "^10.4.16",
    "jsdom": "^28.0.0",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.3.6",
    "typescript": "^5.3.3",
    "vite": "^5.0.8",
    "vitest": "^4.0.18"
  }
}
