FROM node:18-alpine

WORKDIR /app

# Copy only package.json (not lock file to avoid version issues)
COPY package.json ./

# Install dependencies fresh
RUN npm install --legacy-peer-deps

# Copy application
COPY . .

# Expose port 12001 (matching package.json dev script)
EXPOSE 12001

# For development with hot reload
CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0"]
