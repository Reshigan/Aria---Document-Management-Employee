import { useState, useEffect, useRef } from 'react'
import { useRouter } from 'next/router'
import axios from 'axios'

export default function DocumentView() {
  const router = useRouter()
  const { id } = router.query
  const [document, setDocument] = useState(null)
  const [loading, setLoading] = useState(true)
  const [error, setError] = useState(null)
  const [sapPosting, setSapPosting] = useState(false)
  const [sapResult, setSapResult] = useState(null)
  const [reanalyzing, setReanalyzing] = useState(false)
  const [deleting, setDeleting] = useState(false)
  const fileInputRef = useRef(null)

  // Helper function to format document dates
  const formatDocumentDate = (dateString) => {
    if (!dateString) return 'No date'

    try {
      // Handle different date formats
      let date

      // If it's already a valid date string with timezone
      if (dateString.includes('T') && (dateString.includes('+') || dateString.includes('Z'))) {
        date = new Date(dateString)
      } else {
        // If it's a simple date string, parse it
        date = new Date(dateString)
      }

      // Check if date is valid
      if (isNaN(date.getTime())) {
        return 'Invalid Date'
      }

      // Format for South African locale
      return date.toLocaleDateString('en-ZA', {
        year: 'numeric',
        month: 'short',
        day: 'numeric',
        timeZone: 'Africa/Johannesburg'
      })
    } catch (error) {
      console.error('Date formatting error:', error, 'for date:', dateString)
      return 'Invalid Date'
    }
  }

  useEffect(() => {
    if (id) {
      fetchDocument()
    }
  }, [id])

  const fetchDocument = async () => {
    try {
      setLoading(true)
      const token = localStorage.getItem('token')

      const response = await axios.get(`/api/documents/${id}`, {
        headers: {
          'Authorization': `Bearer ${token}`,
          'Content-Type': 'application/json'
        }
      })

      setDocument(response.data)
      setError(null)
    } catch (error) {
      console.error('Error fetching document:', error)
      setError('Failed to load document')
    } finally {
      setLoading(false)
    }
  }

  const handleSapPosting = async () => {
    if (!document) return

    try {
      setSapPosting(true)
      const token = localStorage.getItem('token')

      // Determine document type for SAP posting
      const docType = document.document_category || 'generic'
      let endpoint = '/api/sap/post-generic'

      if (docType === 'invoice') {
        endpoint = '/api/sap/post-invoice'
      } else if (docType === 'receipt') {
        endpoint = '/api/sap/post-receipt'
      } else if (docType === 'contract') {
        endpoint = '/api/sap/post-contract'
      }

      const response = await axios.post(endpoint, {
        document_id: document.id,
        document_data: {
          filename: document.filename,
          content: document.ocr_text,
          metadata: document.processing_result?.business_data || {},
          classification: document.processing_result?.classification || {}
        }
      }, {
        headers: {
          'Authorization': `Bearer ${token}`,
          'Content-Type': 'application/json'
        }
      })

      setSapResult(response.data)
      alert(`SAP Posting Successful!\nDocument Number: ${response.data.document_number}\nStatus: ${response.data.status}`)
    } catch (error) {
      console.error('SAP posting error:', error)
      alert('SAP posting failed: ' + (error.response?.data?.detail || 'Unknown error'))
    } finally {
      setSapPosting(false)
    }
  }

  const handleReanalyze = async () => {
    if (!document) return

    try {
      setReanalyzing(true)
      const token = localStorage.getItem('token')

      const response = await axios.post(`/api/documents/${id}/reanalyze`, {}, {
        headers: {
          'Authorization': `Bearer ${token}`,
          'Content-Type': 'application/json'
        }
      })

      setDocument(response.data.document)
      alert('Document re-analyzed successfully!')
    } catch (error) {
      console.error('Re-analyze error:', error)
      alert('Re-analysis failed: ' + (error.response?.data?.detail || 'Unknown error'))
    } finally {
      setReanalyzing(false)
    }
  }

  const handleDelete = async () => {
    if (!document) return

    if (!confirm(`Are you sure you want to delete "${document.filename}"? This action cannot be undone.`)) {
      return
    }

    try {
      setDeleting(true)
      const token = localStorage.getItem('token')

      await axios.delete(`/api/documents/${id}`, {
        headers: {
          'Authorization': `Bearer ${token}`,
          'Content-Type': 'application/json'
        }
      })

      alert('Document deleted successfully!')
      router.push('/')
    } catch (error) {
      console.error('Delete error:', error)
      alert('Delete failed: ' + (error.response?.data?.detail || 'Unknown error'))
    } finally {
      setDeleting(false)
    }
  }

  const handleReupload = async (event) => {
    const file = event.target.files[0]
    if (!file) return

    try {
      const token = localStorage.getItem('token')
      const formData = new FormData()
      formData.append('file', file)

      const response = await axios.post(`/api/documents/${id}/reupload`, formData, {
        headers: {
          'Authorization': `Bearer ${token}`,
          'Content-Type': 'multipart/form-data'
        }
      })

      setDocument(response.data.document)
      alert('Document re-uploaded and processed successfully!')
    } catch (error) {
      console.error('Re-upload error:', error)
      alert('Re-upload failed: ' + (error.response?.data?.detail || 'Unknown error'))
    }

    // Reset file input
    if (fileInputRef.current) {
      fileInputRef.current.value = ''
    }
  }

  if (loading) {
    return (
      <div style={{
        minHeight: '100vh',
        backgroundColor: '#111827',
        color: 'white',
        display: 'flex',
        alignItems: 'center',
        justifyContent: 'center'
      }}>
        <div style={{ textAlign: 'center' }}>
          <div style={{
            width: '48px',
            height: '48px',
            border: '3px solid #374151',
            borderTop: '3px solid #f59e0b',
            borderRadius: '50%',
            animation: 'spin 1s linear infinite',
            margin: '0 auto 16px'
          }}></div>
          <p>Loading document...</p>
        </div>
      </div>
    )
  }

  if (error || !document) {
    return (
      <div style={{
        minHeight: '100vh',
        backgroundColor: '#111827',
        color: 'white',
        padding: '24px'
      }}>
        <div style={{ textAlign: 'center', paddingTop: '48px' }}>
          <h2 style={{ fontSize: '24px', marginBottom: '16px' }}>Document Not Found</h2>
          <p style={{ color: '#9ca3af', marginBottom: '24px' }}>{error || 'The requested document could not be found.'}</p>
          <button
            onClick={() => router.push('/')}
            style={{
              backgroundColor: '#f59e0b',
              color: 'black',
              padding: '8px 16px',
              borderRadius: '8px',
              border: 'none',
              cursor: 'pointer',
              fontWeight: '500'
            }}
          >
            Back to Dashboard
          </button>
        </div>
      </div>
    )
  }

  return (
    <div style={{
      minHeight: '100vh',
      backgroundColor: '#111827',
      color: 'white'
    }}>
      <div style={{ maxWidth: '1200px', margin: '0 auto', padding: '24px' }}>
        {/* Header */}
        <div style={{
          display: 'flex',
          justifyContent: 'space-between',
          alignItems: 'center',
          marginBottom: '32px'
        }}>
          <button
            onClick={() => router.push('/')}
            style={{
              backgroundColor: 'transparent',
              color: '#9ca3af',
              border: 'none',
              cursor: 'pointer',
              display: 'flex',
              alignItems: 'center',
              gap: '8px'
            }}
          >
            ← Back to Dashboard
          </button>
          <h1 style={{ fontSize: '28px', fontWeight: 'bold' }}>
            {document.filename}
          </h1>
        </div>

        {/* Document Info */}
        <div style={{
          backgroundColor: '#1f2937',
          padding: '24px',
          borderRadius: '12px',
          marginBottom: '24px'
        }}>
          <div style={{ display: 'grid', gridTemplateColumns: 'repeat(auto-fit, minmax(200px, 1fr))', gap: '16px' }}>
            <div>
              <label style={{ color: '#9ca3af', fontSize: '14px' }}>Document Type</label>
              <p style={{ fontWeight: '500' }}>
                {document.document_category ?
                  document.document_category.charAt(0).toUpperCase() + document.document_category.slice(1) :
                  'Unknown'}
              </p>
            </div>
            <div>
              <label style={{ color: '#9ca3af', fontSize: '14px' }}>Upload Date</label>
              <p style={{ fontWeight: '500' }}>{formatDocumentDate(document.upload_date)}</p>
            </div>
            <div>
              <label style={{ color: '#9ca3af', fontSize: '14px' }}>Status</label>
              <p style={{ fontWeight: '500' }}>{document.status || 'Active'}</p>
            </div>
            <div>
              <label style={{ color: '#9ca3af', fontSize: '14px' }}>File Size</label>
              <p style={{ fontWeight: '500' }}>
                {document.size ? `${Math.round(document.size / 1024)} KB` : 'Unknown'}
              </p>
            </div>
          </div>
        </div>

        {/* Document Management Actions */}
        <div style={{
          backgroundColor: '#1f2937',
          padding: '24px',
          borderRadius: '12px',
          marginBottom: '24px',
          border: '1px solid #3b82f6'
        }}>
          <h2 style={{ fontSize: '20px', fontWeight: '600', marginBottom: '16px', color: '#3b82f6' }}>
            📄 Document Management
          </h2>
          <div style={{ display: 'flex', gap: '12px', flexWrap: 'wrap' }}>
            <button
              onClick={() => fileInputRef.current?.click()}
              style={{
                backgroundColor: '#3b82f6',
                color: 'white',
                padding: '12px 24px',
                borderRadius: '8px',
                border: 'none',
                cursor: 'pointer',
                fontWeight: '600',
                display: 'flex',
                alignItems: 'center',
                gap: '8px'
              }}
            >
              🔄 Re-upload File
            </button>
            <button
              onClick={handleReanalyze}
              disabled={reanalyzing}
              style={{
                backgroundColor: reanalyzing ? '#6b7280' : '#10b981',
                color: 'white',
                padding: '12px 24px',
                borderRadius: '8px',
                border: 'none',
                cursor: reanalyzing ? 'not-allowed' : 'pointer',
                fontWeight: '600',
                display: 'flex',
                alignItems: 'center',
                gap: '8px'
              }}
            >
              {reanalyzing ? '⏳ Re-analyzing...' : '🔍 Re-analyze Document'}
            </button>
            <button
              onClick={handleDelete}
              disabled={deleting}
              style={{
                backgroundColor: deleting ? '#6b7280' : '#ef4444',
                color: 'white',
                padding: '12px 24px',
                borderRadius: '8px',
                border: 'none',
                cursor: deleting ? 'not-allowed' : 'pointer',
                fontWeight: '600',
                display: 'flex',
                alignItems: 'center',
                gap: '8px'
              }}
            >
              {deleting ? '⏳ Deleting...' : '🗑️ Delete Document'}
            </button>
          </div>
          <input
            ref={fileInputRef}
            type="file"
            accept=".pdf,.jpg,.jpeg,.png,.tiff,.bmp"
            onChange={handleReupload}
            style={{ display: 'none' }}
          />
          <p style={{ color: '#9ca3af', fontSize: '14px', marginTop: '12px' }}>
            Manage your document: re-upload a new version, re-analyze with updated AI, or delete permanently.
          </p>
        </div>

        {/* SAP Integration Section */}
        <div style={{
          backgroundColor: '#1f2937',
          padding: '24px',
          borderRadius: '12px',
          marginBottom: '24px',
          border: '1px solid #f59e0b'
        }}>
          <div style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'center', marginBottom: '16px' }}>
            <h2 style={{ fontSize: '20px', fontWeight: '600', color: '#f59e0b' }}>
              🏢 SAP Integration
            </h2>
            <button
              onClick={handleSapPosting}
              disabled={sapPosting}
              style={{
                backgroundColor: sapPosting ? '#6b7280' : '#f59e0b',
                color: sapPosting ? '#9ca3af' : 'black',
                padding: '12px 24px',
                borderRadius: '8px',
                border: 'none',
                cursor: sapPosting ? 'not-allowed' : 'pointer',
                fontWeight: '600',
                display: 'flex',
                alignItems: 'center',
                gap: '8px'
              }}
            >
              {sapPosting ? '⏳ Posting...' : '📤 Post to SAP'}
            </button>
          </div>

          <p style={{ color: '#9ca3af', marginBottom: '16px' }}>
            Post this document to SAP for financial processing and record keeping.
          </p>

          {/* SAP Status */}
          {document.processing_result?.sap_ready && (
            <div style={{
              backgroundColor: '#065f46',
              color: '#10b981',
              padding: '12px',
              borderRadius: '8px',
              marginBottom: '16px'
            }}>
              ✅ Document is SAP-ready with extracted business data
            </div>
          )}

          {/* Business Data Preview */}
          {document.processing_result?.business_data && (
            <div style={{
              backgroundColor: '#111827',
              padding: '16px',
              borderRadius: '8px',
              marginTop: '16px'
            }}>
              <h3 style={{ fontSize: '16px', fontWeight: '500', marginBottom: '12px', color: '#f59e0b' }}>
                Extracted Business Data:
              </h3>
              <div style={{ display: 'grid', gridTemplateColumns: 'repeat(auto-fit, minmax(200px, 1fr))', gap: '12px' }}>
                {Object.entries(document.processing_result.business_data).map(([key, value]) => (
                  <div key={key}>
                    <label style={{ color: '#9ca3af', fontSize: '12px', textTransform: 'capitalize' }}>
                      {key.replace(/_/g, ' ')}
                    </label>
                    <p style={{ fontWeight: '500', fontSize: '14px' }}>
                      {Array.isArray(value) ? value.join(', ') : String(value)}
                    </p>
                  </div>
                ))}
              </div>
            </div>
          )}

          {/* SAP Result */}
          {sapResult && (
            <div style={{
              backgroundColor: '#065f46',
              color: '#10b981',
              padding: '16px',
              borderRadius: '8px',
              marginTop: '16px'
            }}>
              <h3 style={{ fontSize: '16px', fontWeight: '500', marginBottom: '8px' }}>
                ✅ SAP Posting Successful
              </h3>
              <p><strong>Document Number:</strong> {sapResult.document_number}</p>
              <p><strong>Transaction:</strong> {sapResult.transaction_code}</p>
              <p><strong>Status:</strong> {sapResult.status}</p>
            </div>
          )}
        </div>

        {/* OCR Content */}
        <div style={{
          backgroundColor: '#1f2937',
          padding: '24px',
          borderRadius: '12px',
          marginBottom: '24px'
        }}>
          <h2 style={{ fontSize: '20px', fontWeight: '600', marginBottom: '16px' }}>
            Document Content
          </h2>
          <div style={{
            backgroundColor: '#111827',
            padding: '16px',
            borderRadius: '8px',
            maxHeight: '400px',
            overflowY: 'auto'
          }}>
            <pre style={{
              whiteSpace: 'pre-wrap',
              fontFamily: 'monospace',
              fontSize: '14px',
              lineHeight: '1.5',
              margin: 0
            }}>
              {document.ocr_text || 'No text content available'}
            </pre>
          </div>
        </div>

        {/* Classification Results */}
        {document.processing_result?.classification && (
          <div style={{
            backgroundColor: '#1f2937',
            padding: '24px',
            borderRadius: '12px',
            marginBottom: '24px'
          }}>
            <h2 style={{ fontSize: '20px', fontWeight: '600', marginBottom: '16px' }}>
              AI Classification Results
            </h2>
            <div style={{
              backgroundColor: '#111827',
              padding: '16px',
              borderRadius: '8px'
            }}>
              <div style={{ display: 'grid', gap: '12px' }}>
                {Object.entries(document.processing_result.classification).map(([key, value]) => (
                  <div key={key}>
                    <label style={{ color: '#9ca3af', fontSize: '14px', textTransform: 'capitalize' }}>
                      {key.replace(/_/g, ' ')}
                    </label>
                    <p style={{ fontWeight: '500', fontSize: '14px' }}>
                      {typeof value === 'object' ? JSON.stringify(value, null, 2) : String(value)}
                    </p>
                  </div>
                ))}
              </div>
            </div>
          </div>
        )}

        {/* Metadata */}
        {document.metadata && Object.keys(document.metadata).length > 0 && (
          <div style={{
            backgroundColor: '#1f2937',
            padding: '24px',
            borderRadius: '12px'
          }}>
            <h2 style={{ fontSize: '20px', fontWeight: '600', marginBottom: '16px' }}>
              Document Metadata
            </h2>
            <div style={{ display: 'grid', gap: '12px' }}>
              {Object.entries(document.metadata).map(([key, value]) => (
                <div key={key}>
                  <label style={{ color: '#9ca3af', fontSize: '14px', textTransform: 'capitalize' }}>
                    {key.replace(/_/g, ' ')}
                  </label>
                  <p style={{ fontWeight: '500', fontSize: '14px' }}>
                    {typeof value === 'object' ? JSON.stringify(value, null, 2) : String(value)}
                  </p>
                </div>
              ))}
            </div>
          </div>
        )}
      </div>

      <style jsx>{`
        @keyframes spin {
          0% { transform: rotate(0deg); }
          100% { transform: rotate(360deg); }
        }
      `}</style>
    </div>
  )
}