# ============================================
# ARIA Configuration Template
# Copy this file to .env and update values
# ============================================

# ============================================
# Application Settings
# ============================================
APP_NAME=ARIA
APP_VERSION=2.0.0
ENVIRONMENT=development
DEBUG=false
LOG_LEVEL=INFO

# ============================================
# API Configuration
# ============================================
API_V1_PREFIX=/api/v1
API_V2_PREFIX=/api/v2
BACKEND_CORS_ORIGINS=["http://localhost:3000"]
ALLOWED_HOSTS=["*"]

# ============================================
# Security Settings
# ============================================
# IMPORTANT: Generate a secure secret key using:
# python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=CHANGE_THIS_TO_A_SECURE_32_CHARACTER_KEY
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Password Policy
PASSWORD_MIN_LENGTH=8
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_NUMBERS=true
PASSWORD_REQUIRE_SPECIAL=true

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# Two-Factor Authentication
ENABLE_2FA=false
2FA_ISSUER_NAME=ARIA

# ============================================
# Database Configuration (PostgreSQL)
# ============================================
POSTGRES_SERVER=postgres
POSTGRES_USER=aria_user
POSTGRES_PASSWORD=CHANGE_THIS_PASSWORD
POSTGRES_DB=aria_db
POSTGRES_PORT=5432

# Database Pool Settings
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=40
DB_POOL_PRE_PING=true
DB_ECHO=false

# ============================================
# Redis Configuration
# ============================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=CHANGE_THIS_PASSWORD
REDIS_POOL_SIZE=10
REDIS_DECODE_RESPONSES=true

# ============================================
# MinIO (Object Storage)
# ============================================
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=CHANGE_THIS_SECRET_KEY
MINIO_USE_SSL=false
MINIO_BUCKET_DOCUMENTS=documents
MINIO_BUCKET_MODELS=models
MINIO_BUCKET_BACKUPS=backups

# ============================================
# Elasticsearch Configuration
# ============================================
ELASTICSEARCH_HOST=elasticsearch
ELASTICSEARCH_PORT=9200
ELASTICSEARCH_USER=elastic
ELASTICSEARCH_PASSWORD=CHANGE_THIS_PASSWORD
ELASTICSEARCH_INDEX_PREFIX=aria

# ============================================
# SAP Configuration
# ============================================
# SAP RFC Connection
SAP_ASHOST=sap.example.com
SAP_SYSNR=00
SAP_CLIENT=100
SAP_USER=sap_username
SAP_PASSWORD=CHANGE_THIS_PASSWORD
SAP_LANG=EN
SAP_ROUTER=

# SAP REST API (for S/4HANA)
SAP_USE_REST=false
SAP_REST_URL=https://sap-s4.example.com/sap/opu/odata/
SAP_REST_USERNAME=rest_user
SAP_REST_PASSWORD=CHANGE_THIS_PASSWORD

# SAP Connection Pool
SAP_MAX_CONNECTIONS=5
SAP_CONNECTION_TIMEOUT=30

# SAP Transaction Settings
SAP_AUTO_COMMIT=true
SAP_BATCH_SIZE=100

# ============================================
# Email Configuration (SMTP)
# ============================================
SMTP_TLS=true
SMTP_PORT=587
SMTP_HOST=smtp.gmail.com
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password

# Email Settings
EMAILS_FROM_EMAIL=noreply@example.com
EMAILS_FROM_NAME=ARIA
EMAIL_RESET_TOKEN_EXPIRE_HOURS=48
EMAIL_TEMPLATES_DIR=templates/email
EMAIL_MAX_BATCH_SIZE=100

# Email Features
EMAIL_ENABLE_HTML=true
EMAIL_ENABLE_ATTACHMENTS=true
EMAIL_MAX_ATTACHMENT_SIZE=10485760

# ============================================
# Slack Configuration (Optional)
# ============================================
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_SIGNING_SECRET=your-signing-secret
SLACK_DEFAULT_CHANNEL=#general
SLACK_ERROR_CHANNEL=#errors

# Slack Features
SLACK_ENABLE_INTERACTIVE=true
SLACK_ENABLE_NOTIFICATIONS=true
SLACK_NOTIFICATION_PRIORITY=high

# ============================================
# Microsoft Teams Configuration (Optional)
# ============================================
TEAMS_WEBHOOK_URL=https://outlook.office.com/webhook/...
TEAMS_TENANT_ID=your-tenant-id
TEAMS_CLIENT_ID=your-client-id
TEAMS_CLIENT_SECRET=your-client-secret

# Teams Features
TEAMS_ENABLE_ADAPTIVE_CARDS=true
TEAMS_ENABLE_MENTIONS=true

# ============================================
# ML Model Configuration
# ============================================
MODEL_CACHE_DIR=/app/models
USE_GPU=true
CUDA_VISIBLE_DEVICES=0
BATCH_SIZE=8
MAX_SEQUENCE_LENGTH=512
MODEL_INFERENCE_TIMEOUT=60

# Model Selection
DONUT_MODEL=naver-clova-ix/donut-base-finetuned-docvqa
LAYOUTLM_MODEL=microsoft/layoutlmv3-base
TROCR_MODEL=microsoft/trocr-base-printed

# OCR Settings
OCR_ENGINE=paddleocr
OCR_CONFIDENCE_THRESHOLD=0.85
ENABLE_HANDWRITING_RECOGNITION=true

# ============================================
# Document Processing Configuration
# ============================================
MAX_UPLOAD_SIZE=52428800
ALLOWED_EXTENSIONS=["pdf","png","jpg","jpeg","xlsx","xls","csv","docx"]

# Processing Settings
EXTRACTION_CONFIDENCE_THRESHOLD=0.90
AUTO_VALIDATE=true
AUTO_POST_TO_SAP=false

# Document Types
SUPPORTED_DOCUMENT_TYPES=["invoice","purchase_order","remittance","proof_of_delivery"]

# Processing Limits
MAX_CONCURRENT_PROCESSING=10
PROCESSING_TIMEOUT=300
MAX_RETRY_ATTEMPTS=3

# ============================================
# Celery Configuration
# ============================================
CELERY_BROKER_URL=amqp://guest:guest@rabbitmq:5672//
CELERY_RESULT_BACKEND=redis://redis:6379/1

# Celery Settings
CELERY_TASK_SERIALIZER=json
CELERY_RESULT_SERIALIZER=json
CELERY_ACCEPT_CONTENT=["json"]
CELERY_TIMEZONE=UTC
CELERY_ENABLE_UTC=true

# Celery Workers
CELERY_WORKERS=4
CELERY_TASK_TRACK_STARTED=true
CELERY_TASK_TIME_LIMIT=300
CELERY_TASK_SOFT_TIME_LIMIT=270

# Celery Queues
CELERY_DEFAULT_QUEUE=default
CELERY_QUEUES=["default","document_processing","sap_posting","notifications"]

# ============================================
# Monitoring Configuration
# ============================================
# Prometheus
PROMETHEUS_PORT=9090
PROMETHEUS_METRICS_PATH=/metrics
PROMETHEUS_ENABLE=true

# Grafana
GRAFANA_PORT=3001
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_THIS_PASSWORD

# Logging
LOG_FORMAT=json
LOG_FILE_PATH=logs/app.log
LOG_MAX_SIZE=100
LOG_BACKUP_COUNT=10
LOG_ROTATE=true

# Sentry (Error Tracking) - Optional
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_SAMPLE_RATE=1.0

# ============================================
# Performance Tuning
# ============================================
# Worker Configuration
WORKERS=4
WORKER_CLASS=uvicorn.workers.UvicornWorker
WORKER_CONNECTIONS=1000
KEEPALIVE=5

# Database Optimization
DB_POOL_RECYCLE=3600
DB_POOL_TIMEOUT=30

# Cache Configuration
CACHE_TTL=300
CACHE_MAX_SIZE=1000

# ML Performance
USE_FP16=false
NUM_THREADS=8

# Memory Settings
MALLOC_ARENA_MAX=2
PYTHONHASHSEED=0
MODEL_CACHE_SIZE=4096
EMBEDDING_CACHE_SIZE=2048
