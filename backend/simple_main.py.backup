# Rate limiting storage
rate_limit_storage = defaultdict(list)

# Database backup utility
backup_util = DatabaseBackup()

# Rate limiting function
def check_rate_limit(client_ip: str, endpoint: str, max_requests: int = 10, window_minutes: int = 1):
    """Check if client has exceeded rate limit"""
    now = time.time()
    window_start = now - (window_minutes * 60)
    
    # Clean old requests
    key = f"{client_ip}:{endpoint}"
    rate_limit_storage[key] = [req_time for req_time in rate_limit_storage[key] if req_time > window_start]
    
    # Check if limit exceeded
    if len(rate_limit_storage[key]) >= max_requests:
        return False
    
    # Add current request
    rate_limit_storage[key].append(now)
    return True

# Database setup
engine = create_engine(settings.DATABASE_URL)
