@app.get("/api/health")
async def comprehensive_health_check(db: Session = Depends(get_db)):
    """Comprehensive health check endpoint"""
    health_status = {
        "status": "healthy",
        "timestamp": datetime.utcnow().isoformat() + "Z",
        "version": "2.0.0",
        "services": {}
    }
    
    # Check database connectivity
    try:
        db.execute(text("SELECT 1"))
        health_status["services"]["database"] = {"status": "healthy", "response_time_ms": 0}
    except Exception as e:
        health_status["services"]["database"] = {"status": "unhealthy", "error": str(e)}
        health_status["status"] = "degraded"
    
    # Check Ollama AI service
    try:
        start_time = time.time()
        response = requests.get("http://localhost:11434/api/tags", timeout=5)
        response_time = (time.time() - start_time) * 1000
        
        if response.status_code == 200:
            health_status["services"]["ollama"] = {
                "status": "healthy", 
                "response_time_ms": round(response_time, 2),
                "models": response.json().get("models", [])
            }
        else:
            health_status["services"]["ollama"] = {"status": "unhealthy", "http_status": response.status_code}
            health_status["status"] = "degraded"
    except Exception as e:
        health_status["services"]["ollama"] = {"status": "unhealthy", "error": str(e)}
        health_status["status"] = "degraded"
    
    # Check file system
    try:
        upload_dir = Path("uploads")
        upload_dir.mkdir(exist_ok=True)
        test_file = upload_dir / ".health_check"
        test_file.write_text("health_check")
        test_file.unlink()
        health_status["services"]["filesystem"] = {"status": "healthy"}
    except Exception as e:
        health_status["services"]["filesystem"] = {"status": "unhealthy", "error": str(e)}
        health_status["status"] = "degraded"
    
    # System metrics
    health_status["metrics"] = {
        "uptime_seconds": time.time() - app.state.start_time if hasattr(app.state, 'start_time') else 0,
        "rate_limit_entries": len(rate_limit_storage)
    }
    
    logger.info(f"Health check completed - Status: {health_status['status']}")
    return health_status

@app.get("/api/metrics")
async def get_metrics(current_user: dict = Depends(get_current_user), db: Session = Depends(get_db)):
    """System metrics endpoint for monitoring"""
    try:
        # Database metrics
        user_count = db.execute(text("SELECT COUNT(*) as count FROM users")).fetchone().count
        doc_count = db.execute(text("SELECT COUNT(*) as count FROM documents")).fetchone().count
        
        # Rate limiting metrics
        active_rate_limits = sum(1 for key, requests in rate_limit_storage.items() 
                               if len(requests) > 0)
        
        metrics = {
            "timestamp": datetime.utcnow().isoformat() + "Z",
            "database": {
                "total_users": user_count,
                "total_documents": doc_count,
                "connection_status": "healthy"
            },
            "rate_limiting": {
                "active_limits": active_rate_limits,
                "total_tracked_ips": len(rate_limit_storage)
            },
            "system": {
                "uptime_seconds": time.time() - app.state.start_time if hasattr(app.state, 'start_time') else 0
            }
        }
        
        logger.info(f"Metrics requested by user {current_user.get('username', 'unknown')}")
        return metrics
        
    except Exception as e:
        logger.error(f"Error generating metrics: {str(e)}")
        raise HTTPException(status_code=500, detail="Error generating metrics")

@app.post("/api/auth/login")
async def login(request: LoginRequest, req: Request, db: Session = Depends(get_db)):
    # Rate limiting
    client_ip = req.client.host
    if not check_rate_limit(client_ip, "login", max_requests=5, window_minutes=5):
        logger.warning(f"Rate limit exceeded for login from {client_ip}")
        raise HTTPException(status_code=429, detail="Too many login attempts. Please try again later.")
    
    logger.info(f"Login attempt for user: {request.username} from {client_ip}")
    
    # Check database for user
    result = db.execute(text("SELECT id, username, hashed_password, email FROM users WHERE username = :username"), 
                       {"username": request.username})
    user = result.fetchone()
    
    if user and request.password == "admin123":  # Simplified for demo
        access_token = create_access_token(data={"sub": user.username})
        logger.info(f"Successful login for user: {request.username}")
        return {
            "access_token": access_token,
            "token_type": "bearer",
            "user": {
                "id": user.id,
                "username": user.username,
                "email": user.email if hasattr(user, 'email') else None
            }
        }
    
    logger.warning(f"Failed login attempt for user: {request.username} from {client_ip}")
    raise HTTPException(status_code=401, detail="Invalid credentials")

@app.post("/api/auth/register")
async def register(request: UserRegistrationRequest, req: Request, db: Session = Depends(get_db)):
    # Rate limiting
    client_ip = req.client.host
    if not check_rate_limit(client_ip, "register", max_requests=3, window_minutes=10):
        logger.warning(f"Rate limit exceeded for registration from {client_ip}")
        raise HTTPException(status_code=429, detail="Too many registration attempts. Please try again later.")
    
    logger.info(f"Registration attempt for user: {request.username} from {client_ip}")
    
    # Check if user already exists
    result = db.execute(text("SELECT id FROM users WHERE username = :username OR email = :email"), 
                       {"username": request.username, "email": request.email})
    existing_user = result.fetchone()
    
    if existing_user:
        logger.warning(f"Registration failed - user already exists: {request.username}")
        raise HTTPException(status_code=400, detail="Username or email already registered")
    
    # Hash password (simplified for demo)
    hashed_password = hashlib.sha256(request.password.encode()).hexdigest()
    
    # Insert new user
    try:
        db.execute(text("""
            INSERT INTO users (username, hashed_password, email, full_name, created_at) 
            VALUES (:username, :hashed_password, :email, :full_name, :created_at)
        """), {
            "username": request.username,
            "hashed_password": hashed_password,
            "email": request.email,
            "full_name": request.full_name,
            "created_at": datetime.utcnow().isoformat()
        })
        db.commit()
        
        logger.info(f"User registered successfully: {request.username}")
        return {"message": "User registered successfully", "username": request.username}
        
    except Exception as e:
        db.rollback()
        logger.error(f"Registration failed for {request.username}: {str(e)}")
        raise HTTPException(status_code=500, detail="Registration failed")

@app.get("/api/auth/me")
async def get_current_user_info(current_user: dict = Depends(get_current_user), db: Session = Depends(get_db)):
    # Get full user information from database
    result = db.execute(text("""
        SELECT id, username, email, full_name, is_admin, created_at, last_login 
        FROM users WHERE id = :user_id
    """), {"user_id": current_user["id"]})
    user = result.fetchone()
    
    if user:
        return {
            "id": user.id,
            "username": user.username,
            "email": user.email,
            "full_name": user.full_name,
            "is_admin": bool(user.is_admin),
            "created_at": user.created_at,
            "last_login": user.last_login
        }
    
    return current_user

@app.put("/api/auth/profile")
async def update_user_profile(
    profile_data: dict,
    current_user: dict = Depends(get_current_user),
    db: Session = Depends(get_db)
):
    """Update user profile information"""
    try:
        # Validate allowed fields
        allowed_fields = ["email", "full_name"]
        update_data = {k: v for k, v in profile_data.items() if k in allowed_fields}
        
        if not update_data:
            raise HTTPException(status_code=400, detail="No valid fields to update")
        
        # Build dynamic update query
        set_clauses = []
        params = {"user_id": current_user["id"], "updated_at": datetime.utcnow().isoformat()}
        
        for field, value in update_data.items():
            set_clauses.append(f"{field} = :{field}")
            params[field] = value
        
        set_clauses.append("updated_at = :updated_at")
        
        query = f"UPDATE users SET {', '.join(set_clauses)} WHERE id = :user_id"
        
        db.execute(text(query), params)
        db.commit()
        
        logger.info(f"Profile updated for user {current_user.get('username', 'unknown')}")
        return {"message": "Profile updated successfully"}
        
    except Exception as e:
        db.rollback()
        logger.error(f"Profile update failed for user {current_user.get('username', 'unknown')}: {str(e)}")
        raise HTTPException(status_code=500, detail="Profile update failed")

@app.get("/api/users")
async def list_users(
    current_user: dict = Depends(get_current_user),
    db: Session = Depends(get_db),
    skip: int = 0,
    limit: int = 50
):
    """List users (admin only)"""
    # Check if user is admin
    result = db.execute(text("SELECT is_admin FROM users WHERE id = :user_id"), 
                       {"user_id": current_user["id"]})
    user = result.fetchone()
    
    if not user or not user.is_admin:
        raise HTTPException(status_code=403, detail="Admin access required")
    
    # Get users list
    result = db.execute(text("""
        SELECT id, username, email, full_name, is_active, is_admin, created_at, last_login
        FROM users 
        ORDER BY created_at DESC 
        LIMIT :limit OFFSET :skip
    """), {"limit": limit, "skip": skip})
    
    users = []
    for user in result.fetchall():
        users.append({
            "id": user.id,
            "username": user.username,
            "email": user.email,
            "full_name": user.full_name,
            "is_active": bool(user.is_active),
            "is_admin": bool(user.is_admin),
            "created_at": user.created_at,
            "last_login": user.last_login
        })
    
    logger.info(f"User list requested by admin {current_user.get('username', 'unknown')}")
    return {"users": users, "total": len(users)}

