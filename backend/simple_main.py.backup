    # Simplified auth - just return a mock user for demo
    return {"id": 1, "username": "admin", "email": "admin@aria.local"}

# LLM Service
class LLMService:
    def __init__(self):
        self.ollama_url = "http://localhost:11434"
        self.model = "llama3.2"
    
    async def chat(self, message: str, context: str = None) -> str:
        try:
            # Try Ollama first
            payload = {
                "model": self.model,
                "prompt": f"Context: {context}\n\nUser: {message}\n\nAssistant:",
                "stream": False
            }
            
            response = requests.post(f"{self.ollama_url}/api/generate", json=payload, timeout=30)
            if response.status_code == 200:
                return response.json().get("response", "I'm here to help with your documents!")
            
        except Exception as e:
            print(f"Ollama error: {e}")
        
        # Fallback response
        return f"I understand you're asking about: '{message}'. I'm ready to help with document management tasks!"

llm_service = LLMService()

# Business data storage helper functions
def store_business_data(db: Session, document_id: int, document_category: str, business_data: Dict[str, Any]) -> Dict[str, Any]:
    """Store extracted business data in appropriate tables"""
    try:
        if document_category.lower() == "invoice":
            return store_invoice_data(db, document_id, business_data)
        elif document_category.lower() == "remittance":
            return store_remittance_data(db, document_id, business_data)
        elif document_category.lower() == "pod":
            return store_pod_data(db, document_id, business_data)
        elif document_category.lower() == "contract":
            return store_contract_data(db, document_id, business_data)
        else:
            return {"status": "skipped", "reason": f"No business data extraction for category: {document_category}"}
    except Exception as e:
        logger.error(f"Error storing business data: {str(e)}")
        return {"status": "error", "error": str(e)}

def store_invoice_data(db: Session, document_id: int, invoice_data: Dict[str, Any]) -> Dict[str, Any]:
    """Store invoice business data"""
    try:
        # Insert invoice data
        result = db.execute(text("""
            INSERT INTO invoice_data (
                document_id, invoice_number, invoice_date, due_date, po_number,
                vendor_name, vendor_address, vendor_phone, vendor_email, vendor_tax_id,
                customer_name, customer_address, customer_id,
                subtotal, tax_amount, total_amount, currency,
                payment_terms, payment_method
            ) VALUES (
                :document_id, :invoice_number, :invoice_date, :due_date, :po_number,
                :vendor_name, :vendor_address, :vendor_phone, :vendor_email, :vendor_tax_id,
                :customer_name, :customer_address, :customer_id,
                :subtotal, :tax_amount, :total_amount, :currency,
                :payment_terms, :payment_method
            )
        """), {
            "document_id": document_id,
            "invoice_number": invoice_data.get("invoice_number"),
            "invoice_date": invoice_data.get("invoice_date"),
            "due_date": invoice_data.get("due_date"),
            "po_number": invoice_data.get("po_number"),
            "vendor_name": invoice_data.get("vendor", {}).get("name"),
            "vendor_address": invoice_data.get("vendor", {}).get("address"),
            "vendor_phone": invoice_data.get("vendor", {}).get("phone"),
            "vendor_email": invoice_data.get("vendor", {}).get("email"),
            "vendor_tax_id": invoice_data.get("vendor", {}).get("tax_id"),
            "customer_name": invoice_data.get("customer", {}).get("name"),
            "customer_address": invoice_data.get("customer", {}).get("address"),
            "customer_id": invoice_data.get("customer", {}).get("customer_id"),
            "subtotal": invoice_data.get("subtotal", 0),
            "tax_amount": invoice_data.get("tax_amount", 0),
            "total_amount": invoice_data.get("total_amount", 0),
            "currency": invoice_data.get("currency", "USD"),
            "payment_terms": invoice_data.get("payment_terms"),
            "payment_method": invoice_data.get("payment_method")
        })
        
        invoice_data_id = result.lastrowid
        
        # Insert line items
        line_items = invoice_data.get("line_items", [])
        for i, item in enumerate(line_items):
            db.execute(text("""
                INSERT INTO invoice_line_items (
                    invoice_data_id, line_number, description, quantity, 
                    unit_price, total_amount, tax_rate
                ) VALUES (
                    :invoice_data_id, :line_number, :description, :quantity,
                    :unit_price, :total_amount, :tax_rate
                )
            """), {
                "invoice_data_id": invoice_data_id,
                "line_number": i + 1,
                "description": item.get("description"),
                "quantity": item.get("quantity", 0),
                "unit_price": item.get("unit_price", 0),
                "total_amount": item.get("total_amount", 0),
                "tax_rate": item.get("tax_rate")
            })
        
        db.commit()
        
        return {
            "status": "success",
            "invoice_data_id": invoice_data_id,
            "line_items_count": len(line_items),
            "extracted_data": {
                "invoice_number": invoice_data.get("invoice_number"),
                "vendor": invoice_data.get("vendor", {}).get("name"),
                "customer": invoice_data.get("customer", {}).get("name"),
                "total_amount": invoice_data.get("total_amount", 0),
                "currency": invoice_data.get("currency", "USD")
            }
        }
        
    except Exception as e:
        db.rollback()
        logger.error(f"Error storing invoice data: {str(e)}")
        return {"status": "error", "error": str(e)}

def store_remittance_data(db: Session, document_id: int, remittance_data: Dict[str, Any]) -> Dict[str, Any]:
    """Store remittance business data"""
    try:
        # Insert remittance data
        result = db.execute(text("""
            INSERT INTO remittance_data (
                document_id, remittance_number, payment_date,
                payer_name, payer_account_number, payer_reference,
                payment_method, total_payment_amount, currency,
                bank_name, bank_account_number, bank_routing_number, bank_reference_number
            ) VALUES (
                :document_id, :remittance_number, :payment_date,
                :payer_name, :payer_account_number, :payer_reference,
                :payment_method, :total_payment_amount, :currency,
                :bank_name, :bank_account_number, :bank_routing_number, :bank_reference_number
            )
        """), {
            "document_id": document_id,
            "remittance_number": remittance_data.get("remittance_number"),
            "payment_date": remittance_data.get("payment_date"),
            "payer_name": remittance_data.get("payer", {}).get("name"),
            "payer_account_number": remittance_data.get("payer", {}).get("account_number"),
            "payer_reference": remittance_data.get("payer", {}).get("reference"),
            "payment_method": remittance_data.get("payment_method"),
            "total_payment_amount": remittance_data.get("total_payment_amount", 0),
            "currency": remittance_data.get("currency", "USD"),
            "bank_name": remittance_data.get("bank_details", {}).get("bank_name"),
            "bank_account_number": remittance_data.get("bank_details", {}).get("account_number"),
            "bank_routing_number": remittance_data.get("bank_details", {}).get("routing_number"),
            "bank_reference_number": remittance_data.get("bank_details", {}).get("reference_number")
        })
        
        remittance_data_id = result.lastrowid
        
        # Insert invoice payments
        invoices_paid = remittance_data.get("invoices_paid", [])
        for payment in invoices_paid:
            db.execute(text("""
                INSERT INTO remittance_invoice_payments (
                    remittance_data_id, invoice_number, invoice_date,
                    original_amount, payment_amount, discount_taken, balance_remaining
                ) VALUES (
                    :remittance_data_id, :invoice_number, :invoice_date,
                    :original_amount, :payment_amount, :discount_taken, :balance_remaining
                )
            """), {
                "remittance_data_id": remittance_data_id,
                "invoice_number": payment.get("invoice_number"),
                "invoice_date": payment.get("invoice_date"),
                "original_amount": payment.get("original_amount", 0),
                "payment_amount": payment.get("payment_amount", 0),
                "discount_taken": payment.get("discount_taken", 0),
                "balance_remaining": payment.get("balance_remaining", 0)
            })
        
        db.commit()
        
        return {
            "status": "success",
            "remittance_data_id": remittance_data_id,
            "invoices_paid_count": len(invoices_paid),
            "extracted_data": {
                "remittance_number": remittance_data.get("remittance_number"),
                "payer": remittance_data.get("payer", {}).get("name"),
                "total_payment_amount": remittance_data.get("total_payment_amount", 0),
                "currency": remittance_data.get("currency", "USD")
            }
        }
        
    except Exception as e:
        db.rollback()
        logger.error(f"Error storing remittance data: {str(e)}")
        return {"status": "error", "error": str(e)}

def store_pod_data(db: Session, document_id: int, pod_data: Dict[str, Any]) -> Dict[str, Any]:
    """Store POD business data"""
    try:
        # Insert POD data
        result = db.execute(text("""
            INSERT INTO pod_data (
                document_id, pod_number, delivery_date, delivery_time, tracking_number,
                carrier_name, driver_name, vehicle_id,
                shipper_name, shipper_address,
                recipient_name, recipient_address, contact_person,
                delivery_status, special_instructions, damages_noted
            ) VALUES (
                :document_id, :pod_number, :delivery_date, :delivery_time, :tracking_number,
                :carrier_name, :driver_name, :vehicle_id,
                :shipper_name, :shipper_address,
                :recipient_name, :recipient_address, :contact_person,
                :delivery_status, :special_instructions, :damages_noted
            )
        """), {
            "document_id": document_id,
            "pod_number": pod_data.get("pod_number"),
            "delivery_date": pod_data.get("delivery_date"),
            "delivery_time": pod_data.get("delivery_time"),
            "tracking_number": pod_data.get("tracking_number"),
            "carrier_name": pod_data.get("carrier", {}).get("name"),
            "driver_name": pod_data.get("carrier", {}).get("driver_name"),
            "vehicle_id": pod_data.get("carrier", {}).get("vehicle_id"),
            "shipper_name": pod_data.get("shipper", {}).get("name"),
            "shipper_address": pod_data.get("shipper", {}).get("address"),
            "recipient_name": pod_data.get("recipient", {}).get("name"),
            "recipient_address": pod_data.get("recipient", {}).get("address"),
            "contact_person": pod_data.get("recipient", {}).get("contact_person"),
            "delivery_status": pod_data.get("delivery_status"),
            "special_instructions": pod_data.get("special_instructions"),
            "damages_noted": pod_data.get("damages_noted")
        })
        
        pod_data_id = result.lastrowid
        
        # Insert delivered items
        items_delivered = pod_data.get("items_delivered", [])
        for i, item in enumerate(items_delivered):
            db.execute(text("""
                INSERT INTO pod_items (
                    pod_data_id, item_number, description,
                    quantity_shipped, quantity_delivered, unit, condition_notes
                ) VALUES (
                    :pod_data_id, :item_number, :description,
                    :quantity_shipped, :quantity_delivered, :unit, :condition_notes
                )
            """), {
                "pod_data_id": pod_data_id,
                "item_number": i + 1,
                "description": item.get("description"),
                "quantity_shipped": item.get("quantity_shipped", 0),
                "quantity_delivered": item.get("quantity_delivered", 0),
                "unit": item.get("unit"),
                "condition_notes": item.get("condition")
            })
        
        db.commit()
        
        return {
            "status": "success",
            "pod_data_id": pod_data_id,
            "items_delivered_count": len(items_delivered),
            "extracted_data": {
                "pod_number": pod_data.get("pod_number"),
                "carrier": pod_data.get("carrier", {}).get("name"),
                "recipient": pod_data.get("recipient", {}).get("name"),
                "delivery_status": pod_data.get("delivery_status")
            }
        }
        
    except Exception as e:
        db.rollback()
        logger.error(f"Error storing POD data: {str(e)}")
        return {"status": "error", "error": str(e)}

def store_contract_data(db: Session, document_id: int, contract_data: Dict[str, Any]) -> Dict[str, Any]:
    """Store contract business data"""
    try:
        # Insert contract data
        result = db.execute(text("""
            INSERT INTO contract_data (
                document_id, contract_number, contract_date, effective_date, expiration_date,
                contract_value, currency, payment_terms, renewal_terms, termination_clause
            ) VALUES (
                :document_id, :contract_number, :contract_date, :effective_date, :expiration_date,
                :contract_value, :currency, :payment_terms, :renewal_terms, :termination_clause
            )
        """), {
            "document_id": document_id,
            "contract_number": contract_data.get("contract_number"),
            "contract_date": contract_data.get("contract_date"),
            "effective_date": contract_data.get("effective_date"),
            "expiration_date": contract_data.get("expiration_date"),
            "contract_value": contract_data.get("contract_value"),
            "currency": contract_data.get("currency", "USD"),
            "payment_terms": contract_data.get("payment_terms"),
            "renewal_terms": contract_data.get("renewal_terms"),
            "termination_clause": contract_data.get("termination_clause")
        })
        
        contract_data_id = result.lastrowid
        
        # Insert parties
        parties = contract_data.get("parties", [])
        for party in parties:
            db.execute(text("""
                INSERT INTO contract_parties (
                    contract_data_id, party_name, party_role, party_address, contact_person
                ) VALUES (
                    :contract_data_id, :party_name, :party_role, :party_address, :contact_person
                )
            """), {
                "contract_data_id": contract_data_id,
                "party_name": party.get("name"),
                "party_role": party.get("role"),
                "party_address": party.get("address"),
                "contact_person": party.get("contact_person")
            })
        
        # Insert key terms
        key_terms = contract_data.get("key_terms", [])
        for term in key_terms:
            db.execute(text("""
                INSERT INTO contract_terms (
                    contract_data_id, term_description
                ) VALUES (
                    :contract_data_id, :term_description
                )
            """), {
                "contract_data_id": contract_data_id,
                "term_description": term
            })
        
        db.commit()
        
        return {
            "status": "success",
            "contract_data_id": contract_data_id,
            "parties_count": len(parties),
            "terms_count": len(key_terms),
            "extracted_data": {
                "contract_number": contract_data.get("contract_number"),
                "contract_value": contract_data.get("contract_value"),
                "currency": contract_data.get("currency", "USD")
            }
        }
        
    except Exception as e:
        db.rollback()
        logger.error(f"Error storing contract data: {str(e)}")
        return {"status": "error", "error": str(e)}

