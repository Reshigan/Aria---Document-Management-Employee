        },
        "classification": {
            "category": row.document_category,
            "confidence": row.classification_confidence,
            "reasoning": row.classification_reasoning
        },
        "analysis": {
            "summary": row.content_summary,
            "key_topics": json.loads(row.key_topics) if row.key_topics else [],
            "entities": json.loads(row.entities) if row.entities else [],
            "quality_assessment": row.quality_assessment
        },
        "metadata": json.loads(row.key_information) if row.key_information else {}
    }

@app.post("/api/chat")
async def chat_with_ai(
    request: ChatRequest,
    req: Request,
    current_user: dict = Depends(get_current_user),
    db: Session = Depends(get_db)
):
    # Rate limiting
    client_ip = req.client.host
    if not check_rate_limit(client_ip, "chat", max_requests=20, window_minutes=5):
        logger.warning(f"Rate limit exceeded for chat from {client_ip}")
        raise HTTPException(status_code=429, detail="Too many chat requests. Please wait a moment.")
    
    logger.info(f"Chat request from user {current_user.get('username', 'unknown')}: {request.message[:50]}...")
    
    try:
        # Enhanced system prompt
        system_prompt = """You are ARIA, an AI assistant for document management. You help users with:
        - Organizing and categorizing documents
        - Document search and retrieval
        - Workflow automation
        - File management best practices
        - Security and compliance guidance
        
        Be helpful, professional, and focused on document management tasks."""
        
        context = system_prompt
        
        if request.document_id:
            # Get document context
            result = db.execute(text("SELECT filename FROM documents WHERE id = :id AND owner_id = :owner_id"),
                              {"id": request.document_id, "owner_id": current_user["id"]})
            doc = result.fetchone()
            if doc:
                context += f" The user is asking about document: {doc.filename}"
        
        # Call Ollama API
        response = requests.post(
            "http://localhost:11434/api/generate",
            json={
                "model": "llama3.2:1b",
                "prompt": f"{context}\n\nUser: {request.message}\n\nARIA:",
                "stream": False,
                "options": {
                    "temperature": 0.7,
                    "num_predict": 500
                }
            },
            timeout=60
        )
        
        if response.status_code == 200:
            ai_response = response.json().get("response", "I'm here to help with your documents!")
            logger.info(f"AI response generated successfully for user {current_user.get('username', 'unknown')}")
        else:
            ai_response = "I'm ARIA, your document management assistant. How can I help you today?"
            logger.warning(f"Ollama API returned status {response.status_code}")
            
    except requests.exceptions.Timeout:
        logger.error("Ollama API timeout")
        ai_response = "I'm processing your request, but it's taking longer than expected. Please try again in a moment."
    except Exception as e:
        logger.error(f"Chat error: {str(e)}")
        ai_response = "I'm ARIA, your document management assistant. I'm currently experiencing some technical difficulties, but I'm here to help you with your documents!"
    
    return {
        "response": ai_response,
        "timestamp": datetime.utcnow().isoformat() + "Z",
        "user": current_user.get('username', 'unknown')
    }

@app.get("/api/analytics/dashboard")
async def get_dashboard_analytics(current_user: dict = Depends(get_current_user), db: Session = Depends(get_db)):
