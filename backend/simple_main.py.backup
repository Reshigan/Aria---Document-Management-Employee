@app.post("/api/documents/upload")
async def upload_document(
    file: UploadFile = File(...),
    current_user: dict = Depends(get_current_user),
    db: Session = Depends(get_db)
):
    # Create uploads directory
    upload_dir = Path("uploads")
    upload_dir.mkdir(exist_ok=True)
    
    # Save file
    file_path = upload_dir / file.filename
    with open(file_path, "wb") as buffer:
        content = await file.read()
        buffer.write(content)
    
    # Save to database with initial processing status
    result = db.execute(text("""
        INSERT INTO documents (filename, original_filename, file_path, file_size, content_type, uploaded_by, processing_status, mime_type, document_type, status, posted_to_sap)
        VALUES (:filename, :original_filename, :file_path, :file_size, :content_type, :uploaded_by, 'pending', :mime_type, 'document', 'active', 0)
        RETURNING id
    """), {
        "filename": file.filename,
        "original_filename": file.filename,
        "file_path": str(file_path),
        "file_size": len(content),
        "content_type": file.content_type,
        "mime_type": file.content_type,
        "uploaded_by": current_user["id"]
    })
    document_id = result.fetchone()[0]
    db.commit()
    
    # Process document with OCR and AI classification
    try:
        processing_result = document_processor.process_document(str(file_path), file.filename)
        
        # Update database with processing results
        db.execute(text("""
            UPDATE documents SET 
                extracted_text = :extracted_text,
                ocr_confidence = :ocr_confidence,
                document_category = :document_category,
                classification_confidence = :classification_confidence,
                classification_reasoning = :classification_reasoning,
                key_information = :key_information,
                processing_metadata = :processing_metadata,
                processed_at = :processed_at,
                processing_status = :processing_status,
                content_summary = :content_summary,
                key_topics = :key_topics,
                entities = :entities,
                quality_assessment = :quality_assessment
            WHERE id = :document_id
        """), {
            "document_id": document_id,
            "extracted_text": processing_result.get("ocr_text", ""),
            "ocr_confidence": processing_result.get("confidence_scores", {}).get("ocr_average", 0),
            "document_category": processing_result.get("classification", {}).get("category", "Other"),
            "classification_confidence": processing_result.get("classification", {}).get("confidence", 0),
            "classification_reasoning": processing_result.get("classification", {}).get("reasoning", ""),
            "key_information": json.dumps(processing_result.get("metadata", {})),
            "processing_metadata": json.dumps(processing_result),
            "processed_at": datetime.utcnow(),
            "processing_status": processing_result.get("processing_status", "completed"),
            "content_summary": processing_result.get("content_analysis", {}).get("summary", ""),
            "key_topics": json.dumps(processing_result.get("content_analysis", {}).get("key_topics", [])),
            "entities": json.dumps(processing_result.get("content_analysis", {}).get("entities", [])),
            "quality_assessment": processing_result.get("content_analysis", {}).get("quality_assessment", "")
        })
        db.commit()
        
        # Extract business-specific data
        business_data_result = None
        try:
            business_extractor = BusinessDataExtractor()
            document_category = processing_result.get("classification", {}).get("category", "Other")
            extracted_text = processing_result.get("ocr_text", "")
            
            if extracted_text and document_category:
                business_data = business_extractor.extract_business_data(extracted_text, document_category)
                business_data_result = store_business_data(db, document_id, document_category, business_data)
        except Exception as e:
            logger.error(f"Business data extraction failed: {str(e)}")
            business_data_result = {"error": str(e)}
        
        return {
            "message": "File uploaded and processed successfully",
            "filename": file.filename,
            "size": len(content),
            "document_id": document_id,
            "processing_result": {
                "category": processing_result.get("classification", {}).get("category", "Other"),
                "confidence": processing_result.get("classification", {}).get("confidence", 0),
                "extracted_text_length": len(processing_result.get("ocr_text", "")),
                "processing_status": processing_result.get("processing_status", "completed")
            },
            "business_data": business_data_result
        }
        
    except Exception as e:
        # Update status to error if processing fails
        db.execute(text("""
            UPDATE documents SET processing_status = 'error' WHERE id = :document_id
        """), {"document_id": document_id})
        db.commit()
        
        return {
            "message": "File uploaded but processing failed",
            "filename": file.filename,
            "size": len(content),
            "document_id": document_id,
            "error": str(e)
        }

@app.get("/api/documents")
async def list_documents(current_user: dict = Depends(get_current_user), db: Session = Depends(get_db)):
    result = db.execute(text("""
        SELECT id, filename, status, created_at, file_size, content_type,
               document_category, classification_confidence, processing_status,
               content_summary, ocr_confidence, processed_at
        FROM documents 
        WHERE uploaded_by = :uploaded_by 
        ORDER BY created_at DESC
    """), {"uploaded_by": current_user["id"]})
    
    documents = []
    for row in result:
        documents.append({
            "id": row.id,
            "filename": row.filename,
            "status": row.status or "uploaded",
            "created_at": str(row.created_at),
            "file_size": row.file_size,
            "content_type": row.content_type,
            "document_category": row.document_category,
            "classification_confidence": row.classification_confidence,
            "processing_status": row.processing_status,
            "content_summary": row.content_summary,
            "ocr_confidence": row.ocr_confidence,
            "processed_at": str(row.processed_at) if row.processed_at else None
        })
    
    return {"documents": documents}

@app.get("/api/documents/search")
async def search_documents(
    q: str,
    current_user: dict = Depends(get_current_user),
    db: Session = Depends(get_db)
):
    """Search documents by content, category, or filename"""
    try:
        # Get all user documents for search
        result = db.execute(text("""
            SELECT id, filename, extracted_text, document_category, 
                   classification_confidence, content_summary, key_topics,
                   entities, created_at, file_size, processing_status
            FROM documents 
            WHERE uploaded_by = :uploaded_by AND processing_status = 'completed'
            ORDER BY created_at DESC
        """), {"uploaded_by": current_user["id"]})
        
        documents = []
        for row in result:
            doc_data = {
                "id": row.id,
                "filename": row.filename,
                "ocr_text": row.extracted_text or "",
                "classification": {
                    "category": row.document_category,
                    "confidence": row.classification_confidence
                },
                "metadata": {
                    "summary": row.content_summary,
                    "topics": json.loads(row.key_topics) if row.key_topics else [],
                    "entities": json.loads(row.entities) if row.entities else []
                },
                "created_at": str(row.created_at),
                "file_size": row.file_size,
                "processing_status": row.processing_status
            }
            documents.append(doc_data)
        
        # Use AI-powered search
        search_results = document_processor.search_documents(q, documents)
        
        # Format results for API response
        formatted_results = []
        for doc in search_results:
            formatted_results.append({
                "id": doc["id"],
                "filename": doc["filename"],
                "category": doc.get("classification", {}).get("category", "Other"),
                "confidence": doc.get("classification", {}).get("confidence", 0),
                "summary": doc.get("metadata", {}).get("summary", ""),
                "search_score": doc.get("search_score", 0),
                "text_preview": doc["ocr_text"][:200] + "..." if len(doc["ocr_text"]) > 200 else doc["ocr_text"],
                "created_at": doc["created_at"],
                "file_size": doc["file_size"]
            })
        
        return {
            "query": q,
            "results": formatted_results,
            "total_found": len(formatted_results)
        }
        
    except Exception as e:
        logger.error(f"Search error: {str(e)}")
        raise HTTPException(status_code=500, detail=f"Search failed: {str(e)}")

@app.get("/api/documents/{document_id}")
async def get_document_details(
    document_id: int,
    current_user: dict = Depends(get_current_user),
    db: Session = Depends(get_db)
):
