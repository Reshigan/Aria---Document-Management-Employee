        ]
    }

# Business Data API Endpoints

@app.get("/api/documents/{document_id}/business-data")
async def get_document_business_data(
    document_id: int,
    current_user: dict = Depends(get_current_user),
    db: Session = Depends(get_db)
):
    """Get business data extracted from a document"""
    
    # Check document ownership
    doc_result = db.execute(text("""
        SELECT document_category FROM documents 
        WHERE id = :document_id AND uploaded_by = :user_id
    """), {"document_id": document_id, "user_id": current_user["id"]})
    
    doc_row = doc_result.fetchone()
    if not doc_row:
        raise HTTPException(status_code=404, detail="Document not found")
    
    document_category = doc_row.document_category
    business_data = {}
    
    if document_category and document_category.lower() == "invoice":
        # Get invoice data
        invoice_result = db.execute(text("""
            SELECT i.*, 
                   GROUP_CONCAT(li.description || ' (Qty: ' || li.quantity || ', $' || li.total_amount || ')') as line_items
            FROM invoice_data i
            LEFT JOIN invoice_line_items li ON i.id = li.invoice_data_id
            WHERE i.document_id = :document_id
            GROUP BY i.id
        """), {"document_id": document_id})
        
        invoice_row = invoice_result.fetchone()
        if invoice_row:
            business_data = {
                "type": "invoice",
                "invoice_number": invoice_row.invoice_number,
                "invoice_date": str(invoice_row.invoice_date) if invoice_row.invoice_date else None,
                "due_date": str(invoice_row.due_date) if invoice_row.due_date else None,
                "po_number": invoice_row.po_number,
                "vendor": {
                    "name": invoice_row.vendor_name,
                    "address": invoice_row.vendor_address,
                    "phone": invoice_row.vendor_phone,
                    "email": invoice_row.vendor_email
                },
                "customer": {
                    "name": invoice_row.customer_name,
                    "address": invoice_row.customer_address,
                    "customer_id": invoice_row.customer_id
                },
                "amounts": {
                    "subtotal": float(invoice_row.subtotal) if invoice_row.subtotal else 0,
                    "tax_amount": float(invoice_row.tax_amount) if invoice_row.tax_amount else 0,
                    "total_amount": float(invoice_row.total_amount) if invoice_row.total_amount else 0,
                    "currency": invoice_row.currency
                },
                "payment_terms": invoice_row.payment_terms,
                "line_items_summary": invoice_row.line_items,
                "sap_integration": {
                    "posted": bool(invoice_row.sap_posted),
                    "sap_document_number": invoice_row.sap_document_number,
                    "posting_date": str(invoice_row.sap_posting_date) if invoice_row.sap_posting_date else None
                }
            }
    
    return {
        "document_id": document_id,
        "document_category": document_category,
        "business_data": business_data if business_data else None,
        "message": "Business data extracted successfully" if business_data else "No business data available for this document type"
    }

@app.post("/api/documents/{document_id}/post-to-sap")
async def post_document_to_sap(
    document_id: int,
    current_user: dict = Depends(get_current_user),
    db: Session = Depends(get_db)
):
    """Post document business data to SAP"""
    
    # Check document ownership and get business data
    doc_result = db.execute(text("""
        SELECT document_category FROM documents 
        WHERE id = :document_id AND uploaded_by = :user_id
    """), {"document_id": document_id, "user_id": current_user["id"]})
    
    doc_row = doc_result.fetchone()
    if not doc_row:
        raise HTTPException(status_code=404, detail="Document not found")
    
    document_category = doc_row.document_category
    if not document_category:
        raise HTTPException(status_code=400, detail="Document category not determined")
    
    try:
        # Initialize SAP integration
        sap_config = SAPConfigManager.get_default_config()
        sap_integration = SAPIntegration(sap_config)
        
        result = {"success": False, "message": "Unknown document type"}
        
        if document_category.lower() == "invoice":
            # Get invoice data
            invoice_result = db.execute(text("""
                SELECT * FROM invoice_data WHERE document_id = :document_id
            """), {"document_id": document_id})
            
            invoice_row = invoice_result.fetchone()
            if not invoice_row:
                raise HTTPException(status_code=404, detail="Invoice business data not found")
            
            if invoice_row.sap_posted:
                return {
                    "success": False,
                    "message": "Invoice already posted to SAP",
                    "sap_document_number": invoice_row.sap_document_number
                }
            
            # Convert to dict for SAP posting
            invoice_data = {
                "id": invoice_row.id,
                "document_id": document_id,
                "invoice_number": invoice_row.invoice_number,
                "invoice_date": str(invoice_row.invoice_date) if invoice_row.invoice_date else None,
                "vendor_name": invoice_row.vendor_name,
                "customer_name": invoice_row.customer_name,
                "total_amount": float(invoice_row.total_amount) if invoice_row.total_amount else 0,
                "currency": invoice_row.currency,
                "payment_terms": invoice_row.payment_terms
            }
            
            result = sap_integration.post_invoice_to_sap(invoice_data, db)
        
        return result
        
    except Exception as e:
        logger.error(f"SAP posting error: {str(e)}")
        return {
            "success": False,
            "error": str(e),
            "message": "Failed to post to SAP"
        }

@app.post("/api/documents/upload-excel-remittance")
async def upload_excel_remittance(
    file: UploadFile = File(...),
    current_user: dict = Depends(get_current_user),
    db: Session = Depends(get_db)
):
    """Upload and process Excel remittance file"""
    
    # Validate file type
    if not file.filename.lower().endswith(('.xlsx', '.xls', '.csv')):
        raise HTTPException(status_code=400, detail="Only Excel (.xlsx, .xls) and CSV files are supported")
    
    try:
        # Read file content
        content = await file.read()
        
        # Save file
        upload_dir = Path("uploads")
        upload_dir.mkdir(exist_ok=True)
        
        file_path = upload_dir / file.filename
        with open(file_path, "wb") as f:
            f.write(content)
        
        # Insert document record
        result = db.execute(text("""
            INSERT INTO documents (filename, original_filename, file_path, file_size, content_type, uploaded_by, status)
            VALUES (:filename, :original_filename, :file_path, :file_size, :content_type, :uploaded_by, 'active')
        """), {
            "filename": file.filename,
            "original_filename": file.filename,
            "file_path": str(file_path),
            "file_size": len(content),
            "content_type": file.content_type or "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet",
            "uploaded_by": current_user["id"]
        })
        
        document_id = result.lastrowid
        db.commit()
        
        # Process Excel remittance
        excel_processor = ExcelRemittanceProcessor()
        processing_result = excel_processor.process_excel_remittance(str(file_path))
        
        if processing_result["processing_status"] == "success":
            # Store remittance data
            remittance_data = processing_result["remittance_data"]
            
            # Create a consolidated remittance record
            consolidated_remittance = {
                "remittance_number": f"EXCEL_{document_id}",
                "payment_date": datetime.now().strftime("%Y-%m-%d"),
                "payer": {"name": "Excel Import"},
                "payment_method": "Excel Import",
                "total_payment_amount": remittance_data.get("total_payment_amount", 0),
                "currency": "USD",
                "invoices_paid": []
            }
            
            # Add individual records as invoice payments
            for record in remittance_data.get("records", []):
                if record.get("invoice_number") and record.get("payment_amount"):
                    consolidated_remittance["invoices_paid"].append({
                        "invoice_number": record["invoice_number"],
                        "payment_amount": record["payment_amount"],
                        "original_amount": record.get("payment_amount", 0),
                        "discount_taken": 0,
                        "balance_remaining": 0
                    })
            
            # Store business data
            business_data_result = store_remittance_data(db, document_id, consolidated_remittance)
            
            return {
                "message": "Excel remittance file processed successfully",
                "filename": file.filename,
                "document_id": document_id,
                "processing_result": {
                    "total_records": processing_result["total_records"],
                    "processed_records": len(remittance_data.get("records", [])),
                    "total_payment_amount": remittance_data.get("total_payment_amount", 0),
                    "column_mappings": remittance_data.get("column_mappings", {})
                },
                "business_data": business_data_result
            }
        else:
            return {
                "message": "Excel remittance processing failed",
                "filename": file.filename,
                "document_id": document_id,
                "error": processing_result.get("error", "Unknown error")
            }
            
    except Exception as e:
        logger.error(f"Excel remittance upload error: {str(e)}")
        raise HTTPException(status_code=500, detail=f"Failed to process Excel remittance: {str(e)}")

def init_database():
    """Initialize database with enhanced schema"""
    with engine.connect() as conn:
        # Create users table with enhanced fields
        conn.execute(text("""
            CREATE TABLE IF NOT EXISTS users (
                id INTEGER PRIMARY KEY AUTOINCREMENT,
                username TEXT UNIQUE NOT NULL,
                hashed_password TEXT NOT NULL,
                email TEXT UNIQUE,
                full_name TEXT DEFAULT '',
                is_active BOOLEAN DEFAULT 1,
                is_admin BOOLEAN DEFAULT 0,
                last_login TIMESTAMP,
                created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
                updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
            )
        """))
        
        # Create documents table with enhanced OCR and AI processing fields
        conn.execute(text("""
            CREATE TABLE IF NOT EXISTS documents (
                id INTEGER PRIMARY KEY AUTOINCREMENT,
                filename TEXT NOT NULL,
                original_filename TEXT NOT NULL,
                file_path TEXT NOT NULL,
                file_size INTEGER NOT NULL,
                content_type TEXT,
                status TEXT DEFAULT 'active',
                tags TEXT DEFAULT '',
                description TEXT DEFAULT '',
                owner_id INTEGER NOT NULL,
                created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
                updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
                
                -- OCR and AI Processing Fields
                extracted_text TEXT,
                ocr_confidence REAL,
                document_category TEXT,
                classification_confidence REAL,
                classification_reasoning TEXT,
                key_information TEXT,
                processing_metadata TEXT,
                processed_at TIMESTAMP,
                processing_status TEXT DEFAULT 'pending',
                
                -- AI Analysis Fields
                content_summary TEXT,
                key_topics TEXT,
                entities TEXT,
                quality_assessment TEXT,
                
                -- Search and Indexing
                search_keywords TEXT,
                indexed_at TIMESTAMP,
                
                FOREIGN KEY (owner_id) REFERENCES users (id)
            )
        """))
        
        # Add new columns to existing documents table if they don't exist
        try:
            # Check if content_type column exists
            result = conn.execute(text("PRAGMA table_info(documents)")).fetchall()
            existing_columns = [row[1] for row in result]
            
            new_columns = [
                ("content_type", "TEXT"),
                ("extracted_text", "TEXT"),
                ("ocr_confidence", "REAL"),
                ("document_category", "TEXT"),
                ("classification_confidence", "REAL"),
                ("classification_reasoning", "TEXT"),
                ("key_information", "TEXT"),
                ("processing_metadata", "TEXT"),
                ("processed_at", "TIMESTAMP"),
                ("processing_status", "TEXT DEFAULT 'pending'"),
                ("content_summary", "TEXT"),
                ("key_topics", "TEXT"),
                ("entities", "TEXT"),
                ("quality_assessment", "TEXT"),
                ("search_keywords", "TEXT"),
                ("indexed_at", "TIMESTAMP")
            ]
            
            for column_name, column_type in new_columns:
                if column_name not in existing_columns:
                    conn.execute(text(f"ALTER TABLE documents ADD COLUMN {column_name} {column_type}"))
                    logger.info(f"Added column {column_name} to documents table")
                    
        except Exception as e:
            logger.warning(f"Error adding columns to documents table: {e}")
        
        # Create chat_history table for logging
        conn.execute(text("""
            CREATE TABLE IF NOT EXISTS chat_history (
                id INTEGER PRIMARY KEY AUTOINCREMENT,
                user_id INTEGER NOT NULL,
                message TEXT NOT NULL,
                response TEXT NOT NULL,
                document_id INTEGER,
                created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
                FOREIGN KEY (user_id) REFERENCES users (id),
                FOREIGN KEY (document_id) REFERENCES documents (id)
            )
        """))
        
        # Insert default admin user with enhanced fields
        admin_password_hash = hashlib.sha256("admin123".encode()).hexdigest()
        conn.execute(text("""
            INSERT OR IGNORE INTO users (username, hashed_password, email, full_name, is_admin) 
            VALUES ('admin', :password, 'admin@aria.local', 'System Administrator', 1)
        """), {"password": admin_password_hash})
        
        conn.commit()
        logger.info("Database initialized successfully with enhanced schema")

if __name__ == "__main__":
    # Initialize database on startup
    init_database()
    
    import uvicorn
    uvicorn.run(app, host="0.0.0.0", port=12000)# Simple reports endpoints that return mock data

