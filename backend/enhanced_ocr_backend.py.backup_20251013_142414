# South Africa timezone helper
def get_sa_time():
    """Get current time in South Africa timezone"""
    sa_tz = pytz.timezone('Africa/Johannesburg')
    return datetime.now(sa_tz)

def format_sa_datetime(dt=None):
    """Format datetime in South Africa timezone for display"""
    if dt is None:
        dt = get_sa_time()
    elif dt.tzinfo is None:
        # If naive datetime, assume it's UTC and convert
        utc_tz = pytz.timezone('UTC')
        dt = utc_tz.localize(dt)
        sa_tz = pytz.timezone('Africa/Johannesburg')
        dt = dt.astimezone(sa_tz)
    return dt.strftime('%Y-%m-%dT%H:%M:%S%z')

def format_sa_date(dt=None):
    """Format date in South Africa timezone"""
    if dt is None:
        dt = get_sa_time()
    elif dt.tzinfo is None:
        utc_tz = pytz.timezone('UTC')
        dt = utc_tz.localize(dt)
        sa_tz = pytz.timezone('Africa/Johannesburg')
        dt = dt.astimezone(sa_tz)
    return dt.strftime('%Y-%m-%d')


