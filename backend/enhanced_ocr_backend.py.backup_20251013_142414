class DocumentProcessor:
    """Enhanced document processing with real OCR and AI classification"""

    def __init__(self):
        self.supported_formats = {
            'images': ['.jpg', '.jpeg', '.png', '.bmp', '.tiff', '.gif'],
            'documents': ['.pdf'],
            'text': ['.txt'],
            'spreadsheets': ['.xlsx', '.xls', '.csv']
        }
        
        # Create processing directories
        self.temp_dir = Path("temp_processing")
        self.uploads_dir = Path("uploads")
        self.temp_dir.mkdir(exist_ok=True)
        self.uploads_dir.mkdir(exist_ok=True)

    def process_document(self, file_path: str, filename: str) -> Dict:
        """Complete document processing pipeline with real OCR"""
        try:
            logger.info(f"Starting OCR processing for: {filename}")

            # Initialize result structure
            result = {
                "filename": filename,
                "file_path": file_path,
                "processed_at": format_sa_datetime(),
                "file_size": os.path.getsize(file_path),
                "processing_status": "processing",
                "ocr_text": "",
                "classification": {},
                "metadata": {},
                "confidence_scores": {},
                "errors": []
            }

            # Determine file type and process accordingly
            file_ext = Path(filename).suffix.lower()

            if file_ext in self.supported_formats['images']:
                result = self._process_image(file_path, result)
            elif file_ext in self.supported_formats['documents']:
                result = self._process_pdf(file_path, result)
            elif file_ext in self.supported_formats['text']:
                result = self._process_text_file(file_path, result)
            elif file_ext in self.supported_formats['spreadsheets']:
                result = self._process_spreadsheet(file_path, result)
            else:
                result["errors"].append(f"Unsupported file format: {file_ext}")
                result["processing_status"] = "error"
                return result

            # AI-powered classification and analysis
            if result["ocr_text"] and not result["errors"]:
                result = self._classify_document(result)
                result = self._extract_business_data(result)

            result["processing_status"] = "completed" if not result["errors"] else "completed_with_errors"
            logger.info(f"OCR processing completed for: {filename}")

            return result

        except Exception as e:
            logger.error(f"Error processing document {filename}: {str(e)}")
            result["errors"].append(f"Processing error: {str(e)}")
            result["processing_status"] = "error"
            return result

    def _process_image(self, file_path: str, result: Dict) -> Dict:
        """Process image files with OCR"""
        try:
            # Load and preprocess image
            image = cv2.imread(file_path)
            if image is None:
                # Try with PIL for other formats
                pil_image = Image.open(file_path)
                image = cv2.cvtColor(np.array(pil_image), cv2.COLOR_RGB2BGR)

            # Image preprocessing for better OCR
            processed_image = self._preprocess_image(image)

            # Perform OCR
            ocr_text = pytesseract.image_to_string(processed_image, lang='eng')
            result["ocr_text"] = ocr_text.strip()

            # Get OCR confidence
            try:
                ocr_data = pytesseract.image_to_data(processed_image, output_type=pytesseract.Output.DICT)
                confidences = [int(conf) for conf in ocr_data['conf'] if int(conf) > 0]
                result["confidence_scores"]["ocr_average"] = sum(confidences) / len(confidences) if confidences else 0
            except:
                result["confidence_scores"]["ocr_average"] = 85.0  # Default confidence

            # Image metadata
            result["metadata"]["image_dimensions"] = f"{image.shape[1]}x{image.shape[0]}"
            result["metadata"]["color_channels"] = image.shape[2] if len(image.shape) > 2 else 1

            logger.info(f"OCR extracted {len(result['ocr_text'])} characters from image")

        except Exception as e:
            result["errors"].append(f"Image processing error: {str(e)}")
            logger.error(f"Image processing error: {str(e)}")

        return result

    def _process_pdf(self, file_path: str, result: Dict) -> Dict:
        """Process PDF files with OCR"""
        try:
            # First try to extract text directly from PDF
            with open(file_path, 'rb') as file:
                pdf_reader = PyPDF2.PdfReader(file)
                text_content = ""
                
                for page in pdf_reader.pages:
                    text_content += page.extract_text() + "\n"
                
                if text_content.strip():
                    result["ocr_text"] = text_content.strip()
                    result["metadata"]["extraction_method"] = "direct_text"
                    result["confidence_scores"]["ocr_average"] = 95.0
                    logger.info(f"Extracted text directly from PDF: {len(result['ocr_text'])} characters")
                else:
                    # If no text found, convert to images and OCR
                    result = self._ocr_pdf_images(file_path, result)
                    
        except Exception as e:
            result["errors"].append(f"PDF processing error: {str(e)}")
            logger.error(f"PDF processing error: {str(e)}")

        return result

    def _ocr_pdf_images(self, file_path: str, result: Dict) -> Dict:
        """Convert PDF to images and perform OCR"""
        try:
            # Convert PDF to images
            images = pdf2image.convert_from_path(file_path)
            all_text = ""
            
            for i, image in enumerate(images):
                # Convert PIL image to OpenCV format
                cv_image = cv2.cvtColor(np.array(image), cv2.COLOR_RGB2BGR)
                processed_image = self._preprocess_image(cv_image)
                
                # Perform OCR on each page
                page_text = pytesseract.image_to_string(processed_image, lang='eng')
                all_text += f"--- Page {i+1} ---\n{page_text}\n\n"
            
            result["ocr_text"] = all_text.strip()
            result["metadata"]["extraction_method"] = "ocr_from_images"
            result["metadata"]["total_pages"] = len(images)
            result["confidence_scores"]["ocr_average"] = 80.0
            
            logger.info(f"OCR from PDF images: {len(result['ocr_text'])} characters from {len(images)} pages")
            
        except Exception as e:
            result["errors"].append(f"PDF OCR error: {str(e)}")
            logger.error(f"PDF OCR error: {str(e)}")

        return result

    def _process_text_file(self, file_path: str, result: Dict) -> Dict:
        """Process plain text files"""
        try:
            with open(file_path, 'r', encoding='utf-8') as file:
                result["ocr_text"] = file.read()
                result["metadata"]["extraction_method"] = "direct_read"
                result["confidence_scores"]["ocr_average"] = 100.0
                
        except Exception as e:
            result["errors"].append(f"Text file processing error: {str(e)}")
            logger.error(f"Text file processing error: {str(e)}")

        return result


    def _process_spreadsheet(self, file_path: str, result: Dict) -> Dict:
        """Process Excel and CSV files"""
        try:
            file_ext = Path(file_path).suffix.lower()
            
            if file_ext == '.csv':
                # Process CSV files
                df = pd.read_csv(file_path)
            elif file_ext in ['.xlsx', '.xls']:
                # Process Excel files
                df = pd.read_excel(file_path, sheet_name=None)  # Read all sheets
                
                # If multiple sheets, combine them
                if isinstance(df, dict):
                    combined_text = []
                    for sheet_name, sheet_df in df.items():
                        combined_text.append(f"Sheet: {sheet_name}")
                        combined_text.append(sheet_df.to_string(index=False))
                        combined_text.append("")  # Empty line between sheets
                    result["ocr_text"] = "\n".join(combined_text)
                    result["metadata"]["sheets_processed"] = list(df.keys())
                else:
                    result["ocr_text"] = df.to_string(index=False)
            else:
                result["errors"].append(f"Unsupported spreadsheet format: {file_ext}")
                return result
            
            # For single sheet or CSV
            if file_ext == '.csv' or (file_ext in ['.xlsx', '.xls'] and not isinstance(df, dict)):
                result["ocr_text"] = df.to_string(index=False)
            
            result["metadata"]["extraction_method"] = "pandas_spreadsheet"
            result["metadata"]["rows_processed"] = len(df) if not isinstance(df, dict) else sum(len(sheet) for sheet in df.values())
            result["metadata"]["columns_processed"] = len(df.columns) if not isinstance(df, dict) else "multiple_sheets"
            result["confidence_scores"]["ocr_average"] = 95.0  # High confidence for structured data
            
            logger.info(f"Spreadsheet processed: {len(result['ocr_text'])} characters extracted")
            
        except Exception as e:
            result["errors"].append(f"Spreadsheet processing error: {str(e)}")
            logger.error(f"Spreadsheet processing error: {str(e)}")
        
        return result
    def _preprocess_image(self, image):
        """Preprocess image for better OCR results"""
        try:
            # Convert to grayscale
            gray = cv2.cvtColor(image, cv2.COLOR_BGR2GRAY)
            
            # Apply Gaussian blur to reduce noise
            blurred = cv2.GaussianBlur(gray, (5, 5), 0)
            
            # Apply threshold to get binary image
            _, thresh = cv2.threshold(blurred, 0, 255, cv2.THRESH_BINARY + cv2.THRESH_OTSU)
            
            return thresh
        except:
            # If preprocessing fails, return original grayscale
            return cv2.cvtColor(image, cv2.COLOR_BGR2GRAY)

    def _classify_document(self, result: Dict) -> Dict:
        """Enhanced AI-powered document classification with weighted keywords"""
        text = result["ocr_text"].lower()
        
        # Enhanced classification with weighted keywords
        classification_rules = {
            "Invoice": {
                "primary": ["invoice", "bill", "amount due", "total:", "subtotal", "invoice number", "invoice date"],
                "secondary": ["tax", "payment", "due date", "billing", "charges", "vat"],
                "tertiary": ["company", "address", "phone", "email", "description", "quantity"]
            },
            "Receipt": {
                "primary": ["receipt", "paid", "transaction", "purchase"],
                "secondary": ["thank you", "change", "cash", "card", "payment method"],
                "tertiary": ["store", "location", "time", "date", "item"]
            },
            "Contract": {
                "primary": ["agreement", "contract", "terms", "conditions"],
                "secondary": ["party", "signature", "effective date", "duration"],
                "tertiary": ["obligations", "rights", "responsibilities", "clause"]
            },
            "Legal Document": {
                "primary": ["legal", "court", "law", "attorney"],
                "secondary": ["plaintiff", "defendant", "case", "judgment"],
                "tertiary": ["evidence", "witness", "testimony", "ruling"]
            },
            "Financial Statement": {
                "primary": ["balance sheet", "income statement", "financial"],
                "secondary": ["assets", "liabilities", "revenue", "expenses"],
                "tertiary": ["profit", "loss", "equity", "cash flow"]
            },
            "Report": {
                "primary": ["report", "analysis", "summary"],
                "secondary": ["findings", "conclusion", "recommendation"],
                "tertiary": ["data", "results", "methodology", "overview"]
            },
            "Letter": {
                "primary": ["dear", "sincerely", "regards", "letter"],
                "secondary": ["correspondence", "attention", "subject"],
                "tertiary": ["yours", "best", "kind", "formal"]
            },
            "Form": {
                "primary": ["form", "application", "please fill"],
                "secondary": ["submit", "required", "optional"],
                "tertiary": ["field", "section", "complete", "information"]
            },
            "Certificate": {
                "primary": ["certificate", "certified", "award"],
                "secondary": ["achievement", "completion", "qualification"],
                "tertiary": ["issued", "valid", "authority", "seal"]
            },
            "ID Document": {
                "primary": ["identification", "passport", "license", "id card"],
                "secondary": ["social security", "number", "expires"],
                "tertiary": ["photo", "signature", "address", "birth"]
            },
            "Remittance": {
                "primary": ["remittance", "remittance advice", "payment advice", "payment notification"],
                "secondary": ["payment", "amount paid", "invoice paid", "settlement", "vendor payment"],
                "tertiary": ["reference", "payment date", "bank details", "transfer", "advice"]
            }
        }
        
        scores = {}
        for doc_type, keyword_groups in classification_rules.items():
            # Weighted scoring: primary keywords = 3x, secondary = 2x, tertiary = 1x
            primary_score = sum(3 for keyword in keyword_groups["primary"] if keyword in text)
            secondary_score = sum(2 for keyword in keyword_groups["secondary"] if keyword in text)
            tertiary_score = sum(1 for keyword in keyword_groups["tertiary"] if keyword in text)
            
            total_score = primary_score + secondary_score + tertiary_score
            max_possible = len(keyword_groups["primary"]) * 3 + len(keyword_groups["secondary"]) * 2 + len(keyword_groups["tertiary"]) * 1
            
            if total_score > 0:
                # Normalize and apply confidence boost for strong matches
                base_confidence = total_score / max_possible
                
                # Bonus for primary keyword matches (strong indicators)
                primary_matches = sum(1 for keyword in keyword_groups["primary"] if keyword in text)
                if primary_matches >= 2:
                    base_confidence += 0.2  # 20% bonus for multiple primary matches
                elif primary_matches >= 1:
                    base_confidence += 0.1  # 10% bonus for single primary match
                
                # Bonus for multiple keyword group matches
                groups_matched = 0
                if any(keyword in text for keyword in keyword_groups["primary"]):
                    groups_matched += 1
                if any(keyword in text for keyword in keyword_groups["secondary"]):
                    groups_matched += 1
                if any(keyword in text for keyword in keyword_groups["tertiary"]):
                    groups_matched += 1
                
                if groups_matched >= 3:
                    base_confidence += 0.15  # 15% bonus for all groups
                elif groups_matched >= 2:
                    base_confidence += 0.1   # 10% bonus for two groups
                
                # Cap confidence at 1.0 and ensure minimum threshold
                confidence = min(base_confidence, 1.0)
                if confidence >= 0.7:  # Only include high-confidence classifications
                    scores[doc_type] = confidence
        
        if scores:
            best_match = max(scores, key=scores.get)
            confidence = scores[best_match]
            
            result["classification"] = {
                "document_type": best_match,
                "confidence": confidence,
                "all_scores": scores
            }
        else:
            result["classification"] = {
                "document_type": "Unknown",
                "confidence": 0.0,
                "all_scores": {}
            }
        
        return result

    def _extract_business_data(self, result: Dict) -> Dict:
        """Extract business-relevant data from document text"""
        text = result["ocr_text"]
        
        # Extract common business data patterns
        business_data = {}
        
        # Extract dates (simple pattern)
        import re
        date_patterns = [
            r'\d{1,2}[/-]\d{1,2}[/-]\d{2,4}',
            r'\d{4}[/-]\d{1,2}[/-]\d{1,2}',
            r'[A-Za-z]+ \d{1,2}, \d{4}'
        ]
        
        dates = []
        for pattern in date_patterns:
            dates.extend(re.findall(pattern, text))
        
        if dates:
            business_data["dates_found"] = dates[:5]  # Limit to first 5 dates
        
        # Extract amounts (simple pattern)
        amount_patterns = [
            r'\$\d+[,.]?\d*',
            r'\d+[,.]\d{2}',
            r'total[:\s]+\$?\d+[,.]?\d*'
        ]
        
        amounts = []
        for pattern in amount_patterns:
            amounts.extend(re.findall(pattern, text, re.IGNORECASE))
        
        if amounts:
            business_data["amounts_found"] = amounts[:5]  # Limit to first 5 amounts
        
        # Extract email addresses
        email_pattern = r'\b[A-Za-z0-9._%+-]+@[A-Za-z0-9.-]+\.[A-Z|a-z]{2,}\b'
        emails = re.findall(email_pattern, text)
        if emails:
            business_data["emails_found"] = emails[:3]  # Limit to first 3 emails
        
        # Extract phone numbers (simple pattern)
        phone_pattern = r'\b\d{3}[-.]?\d{3}[-.]?\d{4}\b'
        phones = re.findall(phone_pattern, text)
        if phones:
            business_data["phones_found"] = phones[:3]  # Limit to first 3 phones
        
        result["business_data"] = business_data
        return result

