@app.post('/api/documents/upload')
async def upload_document(file: UploadFile = File(...), current_user: dict = Depends(get_current_user)):
    global DOCUMENT_COUNTER

    try:
        # Save uploaded file with proper file handling
        file_path = doc_processor.uploads_dir / f"{DOCUMENT_COUNTER}_{file.filename}"
        
        # Reset file pointer to beginning and read all content
        await file.seek(0)
        file_content = await file.read()
        
        # Write the content to file
        with open(file_path, "wb") as buffer:
            buffer.write(file_content)

        # Process document with real OCR
        processing_result = doc_processor.process_document(str(file_path), file.filename)
        
        # Create document record
        document = {
            'id': DOCUMENT_COUNTER,
            'title': file.filename,
            'filename': file.filename,
            'upload_date': format_sa_datetime(),
            'size': file.size or processing_result.get('file_size', 0),
            'type': file.filename.split('.')[-1] if '.' in file.filename else 'unknown',
            'user_id': current_user['id'],
            'processing_result': processing_result,
            'ocr_text': processing_result.get('ocr_text', ''),
            'classification': processing_result.get('classification', {}),
            'business_data': processing_result.get('business_data', {}),
            'confidence_scores': processing_result.get('confidence_scores', {}),
            'processing_status': processing_result.get('processing_status', 'completed'),
            'document_category': processing_result.get('classification', {}).get('document_type', 'unknown').lower()
        }

        MOCK_DOCUMENTS.append(document)
        DOCUMENT_COUNTER += 1

        return {
            'message': 'Document uploaded and processed with OCR successfully',
            'document': document,
            'ocr_processing': {
                'status': processing_result.get('processing_status', 'completed'),
                'text_length': len(processing_result.get('ocr_text', '')),
                'classification': processing_result.get('classification', {}),
                'confidence': processing_result.get('confidence_scores', {}),
                'business_data_extracted': len(processing_result.get('business_data', {}))
            },
            'sap_ready': processing_result.get('processing_status') == 'completed'
        }

    except Exception as e:
        logger.error(f"Upload processing error: {str(e)}")
        raise HTTPException(status_code=500, detail=f"Processing error: {str(e)}")

@app.post('/api/documents/{document_id}/sap-post')
async def post_document_to_sap(document_id: int, sap_request: SAPPostRequest, current_user: dict = Depends(get_current_user)):
    """Post processed document to SAP ERP system"""
    try:
        # Find the document
        document = next((doc for doc in MOCK_DOCUMENTS if doc['id'] == document_id), None)
        if not document:
            raise HTTPException(status_code=404, detail='Document not found')
        
        # Check if document belongs to user
        if document.get('user_id') != current_user['id']:
            raise HTTPException(status_code=403, detail='Access denied')
        
        # Check if document processing is completed
        if document.get('processing_status') != 'completed':
            raise HTTPException(status_code=400, detail='Document processing not completed')
        
        # Initialize SAP integration with custom config if provided
        sap_client = sap_integration
        if sap_request.sap_config:
            sap_client = SAPIntegration(sap_request.sap_config)
        
        # Post to SAP
        sap_result = sap_client.post_document_to_sap(document)
        
        # Update document with SAP information
        document['sap_posting'] = {
            'posted_at': time.strftime('%Y-%m-%dT%H:%M:%SZ'),
            'sap_document_number': sap_result.get('sap_document_number'),
            'transaction_code': sap_result.get('transaction_code'),
            'success': sap_result.get('success', False),
            'message': sap_result.get('message', ''),
            'error': sap_result.get('error')
        }
        
        return {
            'message': 'Document posted to SAP successfully' if sap_result.get('success') else 'SAP posting failed',
            'sap_result': sap_result,
            'document_id': document_id,
            'sap_document_number': sap_result.get('sap_document_number')
        }
        
    except HTTPException:
        raise
    except Exception as e:
        logger.error(f"SAP posting error: {str(e)}", exc_info=True)
        raise HTTPException(status_code=500, detail=f"SAP posting error: {str(e)}")

