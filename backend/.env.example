# ARIA ERP - Environment Variables
# Copy this file to .env and update with your values
#
# SECURITY WARNING: Never commit .env files with real secrets to version control!
# Generate secure keys with: python -c "import secrets; print(secrets.token_urlsafe(64))"

# Application
APP_NAME="ARIA ERP"
APP_VERSION="1.0.0"
ENVIRONMENT="development"
DEBUG=True

# Security - REQUIRED: These MUST be set in production (no defaults allowed)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=""  # REQUIRED - Application will fail to start without this
JWT_ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Demo credentials (only for development/testing - leave empty in production)
DEMO_COMPANY_ID=""
DEMO_USER_ID=""

# Database
DATABASE_URL="postgresql://aria_user:aria_password@localhost:5432/aria_erp"
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10

# Redis
REDIS_URL="redis://localhost:6379/0"

# CORS
CORS_ORIGINS="http://localhost:3000,http://localhost:5173"

# File Upload
MAX_FILE_SIZE_MB=10
UPLOAD_DIR="./uploads"

# Email (for notifications)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM="noreply@aria-erp.com"

# AI/OpenAI (for bots)
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4-turbo-preview"

# Sentry (Error tracking)
SENTRY_DSN=""

# South Africa Specific
SARS_API_URL="https://api.sarsefiling.co.za"
SARS_API_KEY=""
