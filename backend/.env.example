# Backend Environment Variables (Example)
# Copy this file to .env and fill in your actual values

# Security
SECRET_KEY=your-secret-key-here-at-least-32-characters-long

# Database  
DATABASE_URL=sqlite:///./aria.db

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,https://yourdomain.com

# JWT Configuration
JWT_EXPIRATION_MINUTES=1440

# File Upload
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=50

# ============================================
# AI Configuration (Bots & Intelligence)
# ============================================

# AI Provider: "ollama" (local, free) or "openai" (cloud, paid)
AI_PROVIDER=ollama

# === OLLAMA CONFIGURATION (Default - Recommended) ===
# Local AI - Free, Private, Fast
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Alternative Ollama models:
# - llama3.2 (Recommended - 8GB RAM, fast & accurate)
# - mistral (Great for South African English)
# - mixtral (Most powerful - needs 16GB+ RAM)
# - phi3 (Lightweight - 4GB RAM, good for low-resource servers)

# === OPENAI CONFIGURATION (Optional) ===
# Cloud AI - Requires API key and costs money
# OPENAI_API_KEY=sk-your-actual-api-key-here
# OPENAI_MODEL=gpt-4-turbo-preview

# Legacy LLM config (for backward compatibility)
LLM_PROVIDER=ollama
LLM_MODEL=llama3.2

# AI Personality Configuration
AI_NAME=ARIA
AI_TONE=professional
AI_LANGUAGE=en
