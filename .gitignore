# Next.js
node_modules/
# Note: .next/ is included in git for Docker production deployment
# But exclude cache and hot-update files (too large for git, not needed for production)
.next/cache/
.next/static/webpack/*.hot-update.*
.next/trace
# Exclude all large webpack cache files
.next/cache/webpack/
*.pack

# Production
build/
dist/

# Environment variables
.env
.env.local
.env.production
.env.development
.env.test

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Database (backend/aria.db is included for Docker deployment)
*.db-journal
*.sqlite-journal

# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd
.Python

# Python virtual environment
venv/
env/
ENV/

# Uploads and test files
backend/uploads/
uploads/
test_*.json
test_*.html
test_*.txt
test_*.pdf
test_*.docx
downloaded_version_*.txt
*.pem

# Development scripts
fix_*.py
convert_*.py
complete_*.py

# Additional database files
aria_document_management.db
*.sqlite
*.sqlite3

# Alembic versions (except init)
backend/alembic/versions/*.py
!backend/alembic/versions/__init__.py

# OS
.DS_Store
Thumbs.db
.vscode/
.idea/
